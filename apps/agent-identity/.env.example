# --- Service ---
NODE_ENV=development
LOG_LEVEL=debug
SERVICE_NAME=agent-identity

# --- HTTP / REST ---
HTTP_HOST=0.0.0.0
HTTP_PORT=4001

# --- gRPC ---
GRPC_HOST=0.0.0.0
GRPC_PORT=4002

# --- Database (matches colber-stack docker-compose) ---
DATABASE_URL=postgresql://colber:colber_dev@localhost:15432/colber

# --- Telemetry ---
PRETTY_LOGS=true

# --- Misc ---
# Optional: tag every log with the deployed commit
# COLBER_COMMIT_SHA=local-dev
