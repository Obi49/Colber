# --- Service ---
NODE_ENV=development
LOG_LEVEL=debug
SERVICE_NAME=insurance

# --- HTTP / REST ---
HTTP_HOST=0.0.0.0
HTTP_PORT=4051

# --- gRPC ---
GRPC_HOST=0.0.0.0
GRPC_PORT=4052

# --- Postgres (policies + simulated escrow + claims) ---
# `colber_insurance` is a separate database, provisioned at deploy time.
DATABASE_URL=postgresql://colber:colber_dev@localhost:15432/colber_insurance

# --- Reputation service (for risk multiplier lookup) ---
REPUTATION_URL=http://localhost:14011

# --- Pricing knobs ---
# Base premium rate in basis points (200 = 2%). Range: 1..10000.
INSURANCE_BASE_RATE_BPS=200
# How long a quote stays valid, in seconds.
INSURANCE_QUOTE_VALIDITY_SECONDS=300
# Hard cap on the sum of locked escrow holdings. Subscribe is rejected if
# the new policy would push the total past this number.
INSURANCE_MAX_GLOBAL_EXPOSURE_USDC=100000
# Default coverage period for a freshly-subscribed policy (hours).
INSURANCE_DEFAULT_POLICY_DURATION_HOURS=168
# In-memory TTL for the reputation score cache.
INSURANCE_REPUTATION_CACHE_TTL_SECONDS=60
# Toggle the admin endpoint that forces escrow transitions / claim decisions.
# Off by default — flip to `true` only in dev/test.
INSURANCE_ADMIN_ENABLED=false

# --- Telemetry ---
PRETTY_LOGS=true

# --- Tests ---
# Set to 1 to enable testcontainers-based live integration tests (off by default).
# COLBER_LIVE_TESTS=1
