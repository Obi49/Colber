# Transport: stdio (default, for local clients) or http (for remote MCP)
COLBER_MCP_TRANSPORT=stdio

# HTTP transport options (ignored if transport=stdio)
COLBER_MCP_HTTP_PORT=14080
COLBER_MCP_HTTP_HOST=0.0.0.0

# Backend service URLs (JSON map). Defaults below mirror the local β-VM ports.
COLBER_BASE_URLS={"identity":"http://localhost:14001","reputation":"http://localhost:14011","memory":"http://localhost:14021","observability":"http://localhost:14031","negotiation":"http://localhost:14041","insurance":"http://localhost:14051"}

# Optional bearer token forwarded to backend services on every request.
# COLBER_AUTH_TOKEN=

# Log level (pino): trace | debug | info | warn | error
COLBER_LOG_LEVEL=info
