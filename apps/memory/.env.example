# --- Service ---
NODE_ENV=development
LOG_LEVEL=debug
SERVICE_NAME=memory

# --- HTTP / REST ---
HTTP_HOST=0.0.0.0
HTTP_PORT=4021

# --- gRPC ---
GRPC_HOST=0.0.0.0
GRPC_PORT=4022

# --- Postgres (matches praxis-stack docker-compose) ---
DATABASE_URL=postgresql://praxis:praxis_dev@localhost:15432/praxis

# --- Qdrant (matches praxis-stack docker-compose; HTTP port 16333) ---
QDRANT_URL=http://localhost:16333
# Optional API key (Qdrant Cloud); leave empty for local dev.
# QDRANT_API_KEY=
QDRANT_COLLECTION=praxis_memories

# --- Embedding provider ---
# `ollama` (default) calls the Ollama HTTP API; `stub` is a deterministic
# in-memory fake meant for tests.
MEMORY_EMBEDDING_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
# nomic-embed-text emits 768-dimensional vectors. Other models change this.
MEMORY_EMBEDDING_DIM=768

# --- Encryption (placeholder KMS) ---
# Base64-encoded 32-byte AES-256 key. ONE GLOBAL KEY for v1; per-tenant KMS
# in a later sprint. Generate with:
# `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`
MEMORY_ENCRYPTION_KEY=AAECAwQFBgcICQoLDA0ODxAREhMUFRYXGBkaGxwdHh8=

# --- Versioning / quotas ---
# Maximum versions retained per memory before older ones are pruned.
MEMORY_MAX_VERSIONS=100

# --- Telemetry ---
PRETTY_LOGS=true

# --- Misc ---
# Optional: tag every log with the deployed commit
# PRAXIS_COMMIT_SHA=local-dev

# --- Tests ---
# Set to 1 to enable testcontainers-based live integration tests (off by default).
# PRAXIS_LIVE_TESTS=1
