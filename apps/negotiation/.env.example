# --- Service ---
NODE_ENV=development
LOG_LEVEL=debug
SERVICE_NAME=negotiation

# --- HTTP / REST ---
HTTP_HOST=0.0.0.0
HTTP_PORT=4041

# --- gRPC ---
GRPC_HOST=0.0.0.0
GRPC_PORT=4042

# --- Postgres (event store + projection) ---
# `praxis_negotiation` is a separate database, provisioned at deploy time.
DATABASE_URL=postgresql://praxis:praxis_dev@localhost:15432/praxis_negotiation

# --- Domain limits ---
NEGOTIATION_DEFAULT_DEADLINE_HOURS=24
NEGOTIATION_MAX_PROPOSALS_PER_NEGOTIATION=200
NEGOTIATION_MAX_PARTIES=16

# --- Telemetry ---
PRETTY_LOGS=true

# --- Tests ---
# Set to 1 to enable testcontainers-based live integration tests (off by default).
# PRAXIS_LIVE_TESTS=1
