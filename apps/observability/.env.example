# --- Service ---
NODE_ENV=development
LOG_LEVEL=debug
SERVICE_NAME=observability

# --- HTTP / REST ---
HTTP_HOST=0.0.0.0
HTTP_PORT=4031

# --- gRPC ---
GRPC_HOST=0.0.0.0
GRPC_PORT=4032

# --- Postgres (alert configs) ---
# `colber_observability` is a separate database, provisioned at deploy
# time. The migration runner below points at it directly.
DATABASE_URL=postgresql://colber:colber_dev@localhost:15432/colber_observability

# --- ClickHouse (logs + traces) ---
# Matches the colber-stack docker-compose mapping (HTTP 18123 → 8123).
# The native protocol is NOT used — we go via HTTP for portability.
CLICKHOUSE_URL=http://localhost:18123
CLICKHOUSE_USER=colber
CLICKHOUSE_PASSWORD=colber_dev
CLICKHOUSE_DATABASE=colber

# --- Ingestion / batching ---
# Flush whichever happens first.
OBSERVABILITY_FLUSH_INTERVAL_MS=1000
OBSERVABILITY_FLUSH_BATCH=500
# Hard cap on events per single ingestion HTTP request (1..1000).
OBSERVABILITY_MAX_EVENTS_PER_REQUEST=1000
# Hard cap on rows returned by a query.
OBSERVABILITY_MAX_QUERY_LIMIT=1000

# --- Retention (TTL on ClickHouse tables) ---
OBSERVABILITY_LOG_TTL_DAYS=30
OBSERVABILITY_SPAN_TTL_DAYS=30

# --- Telemetry ---
PRETTY_LOGS=true

# --- Misc ---
# Optional: tag every log with the deployed commit
# COLBER_COMMIT_SHA=local-dev

# --- Tests ---
# Set to 1 to enable testcontainers-based live integration tests (off by default).
# COLBER_LIVE_TESTS=1
