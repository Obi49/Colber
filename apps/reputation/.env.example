# --- Service ---
NODE_ENV=development
LOG_LEVEL=debug
SERVICE_NAME=reputation

# --- HTTP / REST ---
HTTP_HOST=0.0.0.0
HTTP_PORT=4011

# --- gRPC ---
GRPC_HOST=0.0.0.0
GRPC_PORT=4012

# --- Postgres (matches colber-stack docker-compose) ---
DATABASE_URL=postgresql://colber:colber_dev@localhost:15432/colber

# --- Neo4j (matches colber-stack docker-compose; bolt port 17687) ---
NEO4J_BOLT_URL=bolt://localhost:17687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=colber_dev
NEO4J_DATABASE=neo4j

# --- Redis (matches colber-stack docker-compose; port 16379) ---
REDIS_URL=redis://localhost:16379

# --- Scoring engine v1 ---
# Score points awarded per successful, positively-rated transaction.
REPUTATION_SCORE_TX_DELTA=10
# Penalty subtracted per negative feedback (rating <= 2/5).
REPUTATION_SCORE_NEG_FEEDBACK_PENALTY=40
# Half-life cutoff in days: feedbacks older than this contribute half-weight.
REPUTATION_SCORE_DECAY_DAYS=90
# Cache TTL (seconds) for cached score reads.
REPUTATION_SCORE_CACHE_TTL_SECONDS=60

# --- Attestation key (Ed25519, base64 — 32 bytes private, 32 bytes public) ---
# DO NOT use these in production; this pair is the deterministic test fixture.
# Generate a fresh pair with `node -e "import('@noble/ed25519').then(async ed => { const sk = ed.utils.randomPrivateKey(); const pk = await ed.getPublicKeyAsync(sk); console.log('priv', Buffer.from(sk).toString('base64')); console.log('pub', Buffer.from(pk).toString('base64')); })"`
REPUTATION_PLATFORM_PRIVATE_KEY=AAECAwQFBgcICQoLDA0ODxAREhMUFRYXGBkaGxwdHh8=
REPUTATION_PLATFORM_PUBLIC_KEY=

# --- Telemetry ---
PRETTY_LOGS=true

# --- Misc ---
# Optional: tag every log with the deployed commit
# COLBER_COMMIT_SHA=local-dev

# --- Tests ---
# Set to 1 to enable testcontainers-based live integration tests (off by default).
# COLBER_LIVE_TESTS=1
