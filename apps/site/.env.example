# Colber landing site — public environment variables.
#
# All variables consumed at build time MUST be prefixed with NEXT_PUBLIC_ so
# Next.js inlines them into the static export. The site has no server runtime
# (`output: 'export'`), so anything not inlined at build time is unreadable.

# Public GitHub repo URL — used by every external CTA.
NEXT_PUBLIC_REPO_URL=https://github.com/Obi49/Colber

# Public site URL — used to generate canonical/OG/JSON-LD links.
NEXT_PUBLIC_SITE_URL=https://colber.dev

# GitHub Discussions URL — "Talk to us" CTA.
NEXT_PUBLIC_DISCUSSIONS_URL=https://github.com/Obi49/Colber/discussions

# Contact email — footer.
NEXT_PUBLIC_CONTACT_EMAIL=dof1502.mwm27@gmail.com
