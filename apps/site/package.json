{
  "name": "@colber/site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "description": "Colber landing site (colber.dev) — static Next.js 15 export served behind nginx.",
  "scripts": {
    "dev": "next dev --port 3001",
    "prebuild": "node scripts/copy-diagrams.mjs",
    "build": "next build",
    "start": "next start --port 3001",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "clean": "rm -rf .next out .turbo coverage *.tsbuildinfo"
  },
  "dependencies": {
    "@next/mdx": "^15.0.3",
    "@types/mdx": "^2.0.13",
    "clsx": "^2.1.1",
    "mermaid": "^11.4.0",
    "next": "^15.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@colber/eslint-config": "workspace:*",
    "@colber/tsconfig": "workspace:*",
    "@tailwindcss/postcss": "^4.0.0-beta.4",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.15.0",
    "eslint-config-next": "^15.0.3",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0-beta.4",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
