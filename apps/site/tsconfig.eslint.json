{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": "."
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "content/**/*.ts",
    "test/**/*.ts",
    "test/**/*.tsx",
    "vitest.config.ts",
    "next.config.ts",
    "tailwind.config.ts",
    "eslint.config.js",
    "postcss.config.mjs"
  ],
  "exclude": ["node_modules", ".next", "out", "dist"]
}
