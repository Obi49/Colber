# --- Reputation : clé d'attestation Ed25519 ---
# Générer une vraie paire avec :
# node -e "import('@noble/ed25519').then(async ed => {
#   const sk = ed.utils.randomPrivateKey();
#   const pk = await ed.getPublicKeyAsync(sk);
#   console.log('REPUTATION_PLATFORM_PRIVATE_KEY=' + Buffer.from(sk).toString('base64'));
#   console.log('REPUTATION_PLATFORM_PUBLIC_KEY=' + Buffer.from(pk).toString('base64'));
# })"
REPUTATION_PLATFORM_PRIVATE_KEY=AAECAwQFBgcICQoLDA0ODxAREhMUFRYXGBkaGxwdHh8=
REPUTATION_PLATFORM_PUBLIC_KEY=

# --- Memory : clé de chiffrement AES-256-GCM ---
# Générer avec :
# node -e "console.log('MEMORY_ENCRYPTION_KEY=' + require('crypto').randomBytes(32).toString('base64'))"
MEMORY_ENCRYPTION_KEY=AAECAwQFBgcICQoLDA0ODxAREhMUFRYXGBkaGxwdHh8=
