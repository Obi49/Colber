{
  "name": "@praxis/core-mcp",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "MCP tool registration helper for Praxis services. Provides a small in-memory registry, schema validation via Zod, and a uniform error model.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "lint": "eslint src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@praxis/core-types": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@praxis/eslint-config": "workspace:*",
    "@praxis/tsconfig": "workspace:*",
    "@types/node": "^22.9.0",
    "@vitest/coverage-v8": "^2.1.5",
    "eslint": "^9.15.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
