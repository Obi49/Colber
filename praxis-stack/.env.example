# Copie en .env si tu veux surcharger des valeurs.
# Toutes les valeurs ci-dessous sont des valeurs DEV.

# Postgres
POSTGRES_USER=praxis
POSTGRES_PASSWORD=praxis_dev
POSTGRES_DB=praxis
POSTGRES_PORT=15432

# Redis
REDIS_PORT=16379

# NATS
NATS_PORT=14222
NATS_MONITORING_PORT=18222

# Qdrant
QDRANT_HTTP_PORT=16333
QDRANT_GRPC_PORT=16334

# ClickHouse
CLICKHOUSE_USER=praxis
CLICKHOUSE_PASSWORD=praxis_dev
CLICKHOUSE_DB=praxis
CLICKHOUSE_HTTP_PORT=18123
CLICKHOUSE_NATIVE_PORT=19000

# Neo4j
NEO4J_AUTH=neo4j/praxis_dev
NEO4J_HTTP_PORT=17474
NEO4J_BOLT_PORT=17687

# Ollama (embeddings self-hosted)
OLLAMA_PORT=11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Observability
PROMETHEUS_PORT=19090
GRAFANA_PORT=13000
GRAFANA_USER=admin
GRAFANA_PASSWORD=praxis_dev

# Traefik
TRAEFIK_HTTP_PORT=18000
TRAEFIK_DASHBOARD_PORT=18080
